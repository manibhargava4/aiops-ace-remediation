{
  "title": "ACE Incident Overview",
  "uid": "ace-incident",
  "timezone": "browser",
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "ace-sim CPU (cores)",
      "gridPos": { "x": 0, "y": 0, "w": 16, "h": 9 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.8 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total{job=\"ace-sim\"}[1m])",
          "legendFormat": "cpu cores",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Hung flow threads",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        { "expr": "ace_threads_hung", "refId": "A" }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Messages processed",
      "gridPos": { "x": 16, "y": 4, "w": 8, "h": 5 },
      "targets": [
        { "expr": "ace_messages_processed_total", "refId": "A" }
      ]
    }
  ],
  "schemaVersion": 39
}
