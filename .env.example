# Copy to .env and fill in what you use. .env is gitignored.

# Buggy or fixed ACE flow (the demo toggles this for you)
BUG_MODE=true

# ollama (free, local, default) | anthropic | bedrock
LLM_BACKEND=ollama
OLLAMA_MODEL=qwen3:8b

# Only for LLM_BACKEND=anthropic
ANTHROPIC_API_KEY=

# Optional: create real GitHub issues (fine-grained PAT, Issues: Read+Write)
GITHUB_TOKEN=
GITHUB_REPO=youruser/aiops-ace-remediation
